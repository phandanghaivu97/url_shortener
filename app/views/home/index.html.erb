
<h1>URL Shortener</h1>

<h3 class="mt-3">Encode</h3>
<form id="url-shortener-form">
	<div>
		<label for="long_url">Enter your long URL:</label><br>
		<input type="text" id="long_url" name="long_url" size="60">
    <div id="long_url_err" style="color: red; display: none;"></div>
	</div>
	<div>
		<button type="submit" class="btn-info">Shorten</button>
	</div>
</form>

<div id="short-url-result" style="margin-top: 20px; display: none;">
	<strong>Shortened URL:</strong>
	<a id="short-url-link" href="#" target="_blank" style="word-break: break-all; display: inline-block; max-width: 70%; overflow-wrap: break-word;"></a>
	<button id="copy-short-url-btn" class="btn btn-sm btn-outline-secondary" style="margin-left: 10px;" title="Copy to clipboard">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-clipboard" viewBox="0 0 16 16">
      <path d="M4 1.5H3a2 2 0 0 0-2 2V14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3.5a2 2 0 0 0-2-2h-1v1h1a1 1 0 0 1 1 1V14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3.5a1 1 0 0 1 1-1h1z"/>
      <path d="M9.5 1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-3a.5.5 0 0 1-.5-.5v-1a.5.5 0 0 1 .5-.5zm-3-1A1.5 1.5 0 0 0 5 1.5v1A1.5 1.5 0 0 0 6.5 4h3A1.5 1.5 0 0 0 11 2.5v-1A1.5 1.5 0 0 0 9.5 0z"/>
    </svg> Copy short code
  </button>
</div>

<h3 class="mt-5">Decode</h3>
<form id="decode-shortened-url-form">
  <div>
    <label for="identifier">Enter the short code:</label><br>
    <input type="text" id="identifier" name="identifier" size="60">
    <div id="short_code_err" style="color: red; display: none;"></div>
  </div>
  <div>
    <button type="submit" class="btn-info">Decode</button>
  </div>
</form>
<div id="short-url-decoded-result" style="margin-top: 20px; display: none;">
	<strong>Decoded URL:</strong>
	<a id="short-url-decoded-link" href="#" target="_blank" style="word-break: break-all; display: inline-block; max-width: 100%; overflow-wrap: break-word;"></a>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    function handleShortifyFormSubmit() {
      const form = document.getElementById('url-shortener-form');

      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        clearError("long_url_err");

        const longUrl = document.getElementById('long_url').value;
        const response = await fetch(
          '/encode',
          {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ original_url: longUrl }),
          }
        );
        const data = await response.json();

        if (!response.ok) {
          showError("long_url_err", data.error)
        } else {
          const shortUrl = window.location.origin + '/' + data.identifier;

          displayUrlResult('short-url-result', 'short-url-link', shortUrl);
        }
      });
    }

    function handleDecodeFormSubmit() {
      const form = document.getElementById('decode-shortened-url-form');
      const resultDiv = document.getElementById('short-url-decoded-result');
      const resultLink = document.getElementById('short-url-decoded-link');

      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        clearError("short_code_err");

        const longUrl = document.getElementById('identifier').value;
        const response = await fetch(
          '/decode',
          {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ identifier: longUrl }),
          }
        );
        const data = await response.json();

        if (!response.ok) {
          showError("short_code_err", data.error)
        } else {
          displayUrlResult('short-url-decoded-result', 'short-url-decoded-link', data.original_url);
        }
      });
    }

    function displayUrlResult(resultDivId, resultLinkId, url) {
      const resultDiv = document.getElementById(resultDivId);
      const resultLink = document.getElementById(resultLinkId);

      resultLink.href = url;
      resultLink.textContent = url;
      resultDiv.style.display = 'block';
    }

    async function copyToClipboard(text, buttonElement) {
      try {
        await navigator.clipboard.writeText(text);

        const originalText = buttonElement.textContent;
        buttonElement.textContent = 'Copied!';
        buttonElement.classList.add('btn-success');
        buttonElement.classList.remove('btn-outline-secondary');

        // Reset button after 2 seconds
        setTimeout(() => {
          buttonElement.textContent = originalText;
          buttonElement.classList.remove('btn-success');
          buttonElement.classList.add('btn-outline-secondary');
        }, 2000);
      } catch (err) {
        alert('Failed to copy to clipboard');
      }
    }

    function showError(elementId, text) {
      errorMessageBlock = document.getElementById(elementId)

      errorMessageBlock.style.display = 'block';
      errorMessageBlock.textContent = text;
    }

    function clearError(elementId) {
      document.getElementById(elementId).style.display = 'none';
    }

    function setupCopyButton() {
      const copyButton = document.getElementById('copy-short-url-btn');
      const shortUrlLink = document.getElementById('short-url-link');

      copyButton.addEventListener('click', function() {
        copyToClipboard(shortUrlLink.textContent.split("/").at(-1), copyButton);
      });
    }

    handleShortifyFormSubmit();
    handleDecodeFormSubmit();
    setupCopyButton();
  });
</script>
